# ─────────────────────────────────────────────────────────────────────────────
# MARFA — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── DIRECTUS CMS ──────────────────────────────────────────────────────────────
# URL of your running Directus instance
DIRECTUS_URL=http://localhost:8055

# Directus static token for READ-ONLY access (create in Directus admin > Users)
# This token is used server-side only — never exposed to the browser
DIRECTUS_TOKEN=your-directus-static-token-here

# Domain only (used in next.config.js for image optimization)
DIRECTUS_HOSTNAME=localhost

# ── REVALIDATION ─────────────────────────────────────────────────────────────
# Secret used to validate webhook calls from Directus that trigger ISR revalidation
# Set this same value in Directus Flows webhook action header: x-revalidate-secret
REVALIDATE_SECRET=generate-a-random-32-char-string-here

# ── SITE ──────────────────────────────────────────────────────────────────────
# Public URL of this website (used for OG meta tags, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://marfabolivia.com

# ── FALLBACK MODE ─────────────────────────────────────────────────────────────
# Set to "true" to use local site-config.js instead of fetching from Directus.
# Useful during development before Directus is set up.
USE_LOCAL_CONFIG=true
